import { ScrollView, TextEdit } from "std-widgets.slint";

// Exported so Rust can construct values directly
export struct ClassTileData { name: string, count: string, accent: color }

// A row of up to 3 tiles.  `len` tells how many slots (t0..t2) are filled.
// Rust packs tiles into rows: if the last row has len < 3, fill it;
// otherwise push a new TileRow.
export struct TileRow {
    t0: ClassTileData,
    t1: ClassTileData,
    t2: ClassTileData,
    len: int,
}

// A single note entry shown inside ClassNotesPage
export struct NoteData { id: int, text: string, date: string }

// ─── Class tile ───────────────────────────────────────────────────────────────
component ClassTile inherits Rectangle {
    in property <string> class-name: "";
    in property <string> note-count: "0 notes";
    in property <color>  accent: #2d2459;
    callback clicked();

    horizontal-stretch: 1;
    height: 130px;
    border-radius: 14px;
    background: tile-ta.has-hover ? root.accent.brighter(0.12) : root.accent;

    tile-ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    VerticalLayout {
        padding: 20px;
        spacing: 6px;
        alignment: center;

        Text {
            text: root.class-name;
            font-size: 26px;
            font-weight: 700;
            color: #ffffff;
            horizontal-alignment: center;
            overflow: elide;
        }
        Text {
            text: root.note-count;
            font-size: 11px;
            color: #ffffff70;
            horizontal-alignment: center;
        }
    }
}

// ─── Note item inside a class ─────────────────────────────────────────────────
export component ClassNoteItem inherits Rectangle {
    in property <string> note-text: "NotePreview";
    in property <string> date: "00.00.1999";
    in property <int> index: -1;

    callback delete-note();

    height: 58px;
    border-radius: 8px;
    background: row-ta.has-hover ? #1c1c30 : #161625;

    property <bool> copied: false;

    // Hidden TextInput used only to copy text to clipboard
    copy-input := TextInput {
        width: 0; height: 0;
        text: root.note-text;
        enabled: false;
    }

    row-ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            copy-input.select-all();
            copy-input.copy();
            root.copied = true;
            copy-timer.running = true;
        }
    }

    copy-timer := Timer {
        interval: 1500ms;
        running: false;
        triggered => {
            root.copied = false;
            self.running = false;
        }
    }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 8px;
        spacing: 8px;

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 3px;
            alignment: center;

            Text {
                text: root.copied ? "Copied!" : root.note-text;
                font-size: 14px;
                color: root.copied ? #ff6b6b : #ccccdf;
                overflow: elide;
            }
            Text {
                text: root.date;
                font-size: 11px;
                color: #44445a;
            }
        }

        Rectangle {
            width: 30px;
            height: 30px;
            border-radius: 15px;
            background: del-ta.has-hover ? #b03030 : transparent;

            del-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.delete-note(); }
            }

            Text {
                text: "✖️";
                font-size: 13px;
                color: del-ta.has-hover ? #ffffff : #55556a;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

// ─── Classes grid page ────────────────────────────────────────────────────────
export component ClassesPage inherits Rectangle {
    background: transparent;
    callback class-selected(string);
    callback on-semantic-search(string);
    property <bool> search-open: false;

    // Rows model — managed entirely from Rust via VecModel<TileRow>.
    // Each row holds up to 3 tiles; `len` says how many are filled.
    in-out property <[TileRow]> rows;

    // ── Main layout ───────────────────────────────────────────────────────────
    VerticalLayout {
        spacing: 14px;

        // Header
        HorizontalLayout {
            height: 36px;
            spacing: 10px;

            Text {
                text: "Classes";
                font-size: 20px;
                font-weight: 700;
                color: #dcdcee;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Rectangle {
                width: 36px;
                height: 36px;
                border-radius: 8px;
                background: search-ta.has-hover || root.search-open ? #252540 : transparent;

                search-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.search-open = true; }
                }

                Text {
                    text: "🔍";
                    font-size: 16px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // ── Tile grid — one HorizontalLayout per TileRow, generated by Rust ────
        grid-scroll := ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 12px;
                width: grid-scroll.visible-width;

                for row in root.rows: HorizontalLayout {
                    spacing: 12px;

                    // Filled slots
                    if row.len >= 1: ClassTile {
                        class-name: row.t0.name;
                        note-count: row.t0.count;
                        accent:     row.t0.accent;
                        clicked => { root.class-selected(row.t0.name); }
                    }
                    if row.len >= 2: ClassTile {
                        class-name: row.t1.name;
                        note-count: row.t1.count;
                        accent:     row.t1.accent;
                        clicked => { root.class-selected(row.t1.name); }
                    }
                    if row.len >= 3: ClassTile {
                        class-name: row.t2.name;
                        note-count: row.t2.count;
                        accent:     row.t2.accent;
                        clicked => { root.class-selected(row.t2.name); }
                    }

                    // Invisible spacers keep tile widths uniform in the last row
                    if row.len < 3: Rectangle { horizontal-stretch: 1; }
                    if row.len < 2: Rectangle { horizontal-stretch: 1; }
                }
            }
        }
    }

    // ── Hover tooltip (only when search is closed) ────────────────────────────
    if search-ta.has-hover && !root.search-open: Rectangle {
        x: root.width - (stip.preferred-width + 18px);
        y: 42px;
        width: stip.preferred-width + 18px;
        height: 28px;
        background: #222238;
        border-radius: 6px;
        border-color: #383860;
        border-width: 1px;
        drop-shadow-color: #00000099;
        drop-shadow-blur: 8px;
        drop-shadow-offset-y: 2px;

        stip := Text {
            x: 9px; y: 0;
            height: parent.height;
            text: "Search across all categories";
            font-size: 12px;
            color: #e4e4f4;
            vertical-alignment: center;
        }
    }

    // ── Search overlay (declared last → always on top) ────────────────────────
    if root.search-open: Rectangle {
        x: 0; y: 0;
        width: root.width;
        height: root.height;
        // Dark semi-transparent backdrop
        background: #07071888;

        // Clicking backdrop closes the overlay
        TouchArea {
            clicked => { root.search-open = false; }
        }

        // Glass card — centred horizontally, ~22% from top
        card := Rectangle {
            property <length> card-w: min(540px, root.width - 80px);
            x: (root.width  - self.card-w) / 2;
            y: root.height  * 0.22;
            width:  card-w;
            height: 62px;
            border-radius: 16px;

            // Glass look: semi-transparent dark + subtle bright border
            background: #1a1a3acc;
            border-color: #9090ff22;
            border-width: 1.5px;
            drop-shadow-color: #000000bb;
            drop-shadow-blur:  40px;
            drop-shadow-offset-y: 14px;

            // Absorb pointer events so backdrop doesn't close on card click
            TouchArea { }

            HorizontalLayout {
                padding-left: 18px;
                padding-right: 14px;
                spacing: 12px;

                // Search icon
                Text {
                    text: "🔍";
                    font-size: 17px;
                    width: 22px;
                    vertical-alignment: center;
                    color: #9090c8;
                }

                // Text input + manual placeholder overlay
                Rectangle {
                    horizontal-stretch: 1;

                    search-input := TextInput {
                        width: parent.width;
                        font-size: 16px;
                        color: #e8e8f8;
                        selection-background-color: #5a52e066;
                        selection-foreground-color: #ffffff;
                        vertical-alignment: center;

                        key-pressed(ev) => {
                            if ev.text == Key.Return {
                                root.search-open = false;
                                root.on-semantic-search(search-input.text);
                                accept
                            }
                            reject
                        }
                    }

                    // Placeholder — visible only while input is empty
                    if search-input.text == "": Text {
                        x: 0; y: 0;
                        width: parent.width;
                        height: parent.height;
                        text: "Semantic search";
                        font-size: 16px;
                        color: #50507a;
                        vertical-alignment: center;
                    }
                }

                // Close ×
                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: 14px;
                    background: x-ta.has-hover ? #ffffff18 : transparent;

                    x-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.search-open = false; }
                    }

                    Text {
                        text: "✖️";
                        font-size: 13px;
                        color: x-ta.has-hover ? #c0c0d8 : #606080;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

// ─── Class notes detail page ──────────────────────────────────────────────────
export component ClassNotesPage inherits Rectangle {
    in property <string>     class-name: "";
    in-out property <[NoteData]> notes;
    background: transparent;
    callback go-back();
    // Fired with the note index when user clicks ✕
    callback delete-note(int);
    // Fired when user submits a new note from the input
    callback add-note(string);
    // Fired when user press delete class button
    callback delete-class(string);
    // Fired when user renames the category (new name)
    callback rename-class(string);

    property <bool> editing-name: false;

    VerticalLayout {
        spacing: 12px;

        // ── Header ──────────────────────────────────────────────────────────
        HorizontalLayout {
            height: 36px;
            spacing: 12px;

            // Back button
            Rectangle {
                width: 90px;
                height: 32px;
                border-radius: 8px;
                background: back-ta.has-hover ? #252540 : #1a1a32;
                border-color: #2a2a44;
                border-width: 1px;

                back-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.go-back(); }
                }

                HorizontalLayout {
                    padding-left: 10px;
                    spacing: 6px;
                    alignment: start;

                    Text { text: "←"; font-size: 14px; color: #9898b4; vertical-alignment: center; }
                    Text { text: "Back"; font-size: 13px; color: #9898b4; vertical-alignment: center; }
                }
            }

            // Class name — display or edit mode
            if !root.editing-name: HorizontalLayout {
                horizontal-stretch: 1;
                spacing: 6px;
                alignment: start;

                Text {
                    text: root.class-name;
                    font-size: 20px;
                    font-weight: 700;
                    color: #dcdcee;
                    vertical-alignment: center;
                }

                Rectangle {
                    width: 26px;
                    height: 26px;
                    border-radius: 6px;
                    background: pen-ta.has-hover ? #252540 : transparent;

                    pen-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.editing-name = true; }
                    }

                    Text {
                        text: "✏️";
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            if root.editing-name: Rectangle {
                horizontal-stretch: 1;
                height: 36px;
                border-radius: 8px;
                background: #1a1a32;
                border-color: #6c63ff;
                border-width: 1.5px;

                name-input := TextInput {
                    x: 10px;
                    width: parent.width - 20px;
                    height: parent.height;
                    text: root.class-name;
                    font-size: 18px;
                    font-weight: 700;
                    color: #dcdcee;
                    vertical-alignment: center;

                    key-pressed(ev) => {
                        if ev.text == Key.Return {
                            root.rename-class(self.text);
                            root.editing-name = false;
                            accept
                        } else if ev.text == Key.Escape {
                            root.editing-name = false;
                            accept
                        }
                        reject
                    }
                }
            }

            // Delete class button
            Rectangle {
                width: 128px;
                height: 36px;
                border-radius: 8px;
                background: add-ta.has-hover ? #b3211b : #3d36b0;

                add-ta := TouchArea { 
                    mouse-cursor: pointer;
                    clicked => {
                        root.delete-class(root.class-name);
                    }
                }

                Text {
                    text: "Delete category🗑️";
                    font-size: 13px;
                    color: #a8a6a4;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                
            }
        }

        // Subtitle
        Text {
            text: "Sorted by date  ·  " + root.class-name;
            font-size: 11px;
            color: #44445a;
            height: 16px;
        }

        // ── Notes list ───────────────────────────────────────────────────────
        cn-scroll := ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 4px;
                padding: 2px;
                width: cn-scroll.visible-width - 4px;

                // Dynamic: Rust fills `notes` via VecModel<NoteData>
                for note[i] in root.notes: ClassNoteItem {
                    index: note.id;
                    note-text: note.text;
                    date:      note.date;
                    delete-note => { root.delete-note(note.id); }
                }
            }
        }

        // ── Add note input ───────────────────────────────────────────────────
        Rectangle {
            height: 80px;
            border-radius: 10px;
            background: #12122a;
            border-color: cn-input.has-focus ? #6c63ff : #252545;
            border-width: 1.5px;

            cn-input := TextEdit {
                x: 10px;
                y: 10px;
                width: parent.width - 20px;
                height: parent.height - 20px;
                font-size: 14px;
                wrap: word-wrap;
                placeholder-text: "Add note to \"" + root.class-name + "\"…";

                // Enter (without Shift) submits the note
                key-pressed(ev) => {
                    if ev.text == Key.Return && !ev.modifiers.shift {
                        root.add-note(self.text);
                        self.text = "";
                        accept
                    } else if ev.modifiers.control && ev.text == "v" {
                        self.paste();
                        accept
                    } else if ev.modifiers.control && ev.text == "a" {
                        self.select-all();
                        accept
                    }
                    reject
                }
            }
        }
    }
}
