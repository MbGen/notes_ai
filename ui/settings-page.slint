import { LineEdit, SpinBox } from "std-widgets.slint";

export component SettingsPage inherits Rectangle {
    background: transparent;

    in-out property <string> llm-model;
    in-out property <string> embeddings-model;
    in-out property <int>    search-limit;

    callback save-settings();

    HorizontalLayout {

        // Контент прибит влево, фиксированная ширина
        VerticalLayout {
            width: 400px;
            spacing: 24px;
            alignment: start;

            Text {
                text: "Settings";
                font-size: 20px;
                font-weight: 700;
                color: #dcdcee;
            }

            // LLM model
            VerticalLayout {
                spacing: 6px;
                Text { text: "LLM model"; font-size: 12px; color: #66667a; }
                Rectangle {
                    height: 38px;
                    border-radius: 8px;
                    background: #12122a;
                    border-color: llm-input.has-focus ? #6c63ff : #252545;
                    border-width: 1.5px;

                    llm-input := LineEdit {
                        x: 10px;
                        width: parent.width - 20px;
                        height: parent.height;
                        text <=> root.llm-model;
                        font-size: 14px;
                        placeholder-text: "e.g. qwen3:4b-thinking";
                    }
                }
            }

            // Embeddings model
            VerticalLayout {
                spacing: 6px;
                Text { text: "Embeddings model"; font-size: 12px; color: #66667a; }
                Rectangle {
                    height: 38px;
                    border-radius: 8px;
                    background: #12122a;
                    border-color: emb-input.has-focus ? #6c63ff : #252545;
                    border-width: 1.5px;

                    emb-input := LineEdit {
                        x: 10px;
                        width: parent.width - 20px;
                        height: parent.height;
                        text <=> root.embeddings-model;
                        font-size: 14px;
                        placeholder-text: "e.g. nomic-embed-text-v2-moe:latest";
                    }
                }
            }

            // Search limit
            VerticalLayout {
                spacing: 6px;
                Text { text: "Semantic search results limit"; font-size: 12px; color: #66667a; }
                SpinBox {
                    width: 120px;
                    value <=> root.search-limit;
                    minimum: 1;
                    maximum: 50;
                }
            }

            // Save button
            Rectangle {
                height: 38px;
                width: 120px;
                border-radius: 8px;
                background: save-ta.has-hover ? #5a52e0 : #3d36b0;

                save-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.save-settings(); }
                }

                Text {
                    text: "Save";
                    font-size: 14px;
                    color: #ffffff;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // Заполняет оставшееся пространство справа
        Rectangle { horizontal-stretch: 1; }
    }
}
